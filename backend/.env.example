# Async SQLAlchemy application database URL for production.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/securedesk

# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/securedesk

# Required for JWT signing. Set this to a random 256-bit secret in each environment.
SECRET_KEY=change-this-to-a-random-256-bit-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File upload storage and limits.
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Use development locally and production on Railway.
ENVIRONMENT=development

# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional service integration values used by Docker Compose and teammate modules.
BACKEND_URL=http://localhost:8000

# Email worker - inbound.
IMAP_HOST=imap.example.com
IMAP_USER=helpdesk@example.com
IMAP_PASSWORD=replace-me

# Email worker - outbound / local Mailhog.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# AI service.
ANTHROPIC_API_KEY=replace-me
